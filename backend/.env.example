# Скопируй этот файл в .env и заполни значения

ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/globalanalytics
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=["http://localhost:3000"]

# Получить бесплатно на https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Получить бесплатно на https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Получить бесплатно на https://newsapi.org/register
NEWS_API_KEY=
