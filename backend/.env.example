# Скопируй этот файл в .env и заполни значения

APP_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/globalanalytics
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=["http://localhost:3000","https://responsible-joy-production-ceb3.up.railway.app"]

# World Bank — без ключа, работает сразу
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2

# GDELT — без ключа, работает сразу
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2

# Alpha Vantage — получить бесплатно: https://www.alphavantage.co/support/#api-key
# Free tier: 25 запросов/день, 5 запросов/мин
ALPHA_VANTAGE_API_KEY=

# FRED — получить бесплатно: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI — получить бесплатно: https://newsapi.org/register (Этап 5)
NEWS_API_KEY=
